# tests/fixtures/cat.cyr — agnos stdin->stdout echo loop. The M1 read-path +
# read/write hand-off + EOF proof. STACK buffer (var buf[256] = 256 bytes), so
# NO heap/mmap — keeps the read/write path isolated from the mmap fixture.
# Under CYRIUS_TARGET_AGNOS: SYS_READ=5, SYS_WRITE=1, SYS_EXIT=0.

include "lib/syscalls.cyr"

fn main(): i64 {
    var buf[256];
    while (1 == 1) {
        var n = syscall(SYS_READ, 0, &buf, 256);   # agnos read#5 (fd 0 = stdin)
        if (n <= 0) { return 0; }                  # EOF (0) or error -> done
        syscall(SYS_WRITE, 1, &buf, n);            # agnos write#1
    }
    return 0;
}

var r = main();
syscall(SYS_EXIT, r);
