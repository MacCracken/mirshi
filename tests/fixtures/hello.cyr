# tests/fixtures/hello.cyr — agnos hello (write + exit). The M1 write-path +
# exit-propagation proof. Build agnos-target:
#   cyrius build --agnos tests/fixtures/hello.cyr build/fixtures/hello
# Under CYRIUS_TARGET_AGNOS: SYS_WRITE=1, SYS_EXIT=0. No alloc_init/println, so
# the only syscalls are write#1 then exit#0 (matches the M0-traced ground truth).

include "lib/syscalls.cyr"

fn main(): i64 {
    syscall(SYS_WRITE, 1, "hello, agnos\n", 13);   # agnos write#1
    return 0;
}

var r = main();
syscall(SYS_EXIT, r);                              # agnos exit#0
