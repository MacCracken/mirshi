# mirshi test suite
# Stdlib auto-included via cyrius.cyml
#
# The M0 decode/format logic (src/decode.cyr) is pure — no syscalls, no ptrace —
# so it is fully exercised here under `cyrius test`, hermetically, on any runner.
# The real fork+ptrace trap path is proven separately in scripts/it/m0_trap.sh
# (it needs an actual traced child, which a pure-cyrius .tcyr cannot express).

include "src/decode.cyr"
include "src/translate.cyr"

fn main() {
    alloc_init();

    test_group("smoke");
    assert(1, "true is true");
    assert_eq(1 + 1, 2, "math works");

    # --- agnos number -> name decode ---------------------------------------
    test_group("decode-name");
    assert_streq(agnos_nr_name(0), "exit", "nr 0 = exit");
    assert_streq(agnos_nr_name(1), "write", "nr 1 = write");
    assert_streq(agnos_nr_name(2), "getpid", "nr 2 = getpid");
    assert_streq(agnos_nr_name(27), "mmap", "nr 27 = mmap");
    assert_streq(agnos_nr_name(60), "winsize", "nr 60 = winsize (NOT exit)");
    assert_streq(agnos_nr_name(61), "net_config", "nr 61 = net_config");
    assert_streq(agnos_nr_name(36), "unknown", "nr 36 = unknown (unmirrored)");
    assert_streq(agnos_nr_name(99), "unknown", "nr 99 = unknown (out of surface)");

    # --- register extraction from a synthetic user_regs_struct -------------
    # Catches the two classic ptrace bugs: reading rax (not orig_rax) for the
    # number, and reading rcx (not r10) for arg4.
    test_group("decode-regs");
    var regs = alloc(USER_REGS_SIZE);
    store64(regs + 120, 1);        # orig_rax = write#1
    store64(regs + 80, 0 - 38);    # rax = -ENOSYS (must be ignored)
    store64(regs + 112, 1);        # rdi  = a0 (fd 1)
    store64(regs + 104, 0x4000);   # rsi  = a1 (buf ptr)
    store64(regs + 96, 2);         # rdx  = a2 (count)
    store64(regs + 56, 7);         # r10  = a3
    assert_eq(decode_nr(regs), 1, "decode_nr reads orig_rax not rax");
    assert_eq(decode_arg(regs, 0), 1, "arg0 = rdi");
    assert_eq(decode_arg(regs, 1), 0x4000, "arg1 = rsi");
    assert_eq(decode_arg(regs, 2), 2, "arg2 = rdx");
    assert_eq(decode_arg(regs, 3), 7, "arg3 = r10 not rcx");

    # --- arity + pointer-arg tables ----------------------------------------
    test_group("decode-shape");
    assert_eq(agnos_argc(2), 0, "getpid arity 0");
    assert_eq(agnos_argc(1), 3, "write arity 3");
    assert_eq(agnos_argc(31), 4, "rename arity 4 (a4=r10)");
    assert_eq(agnos_ptrmask(1), 2, "write buf is arg1");
    assert_eq(agnos_ptrmask(33), 5, "stat path+statbuf are arg0+arg2");
    assert_eq(agnos_ptrmask(2), 0, "getpid has no pointer args");

    # --- full event formatting (the same lines the golden IT asserts) ------
    test_group("format");
    var line = alloc(256);
    format_event(line, 2, 0, 0, 0, 0);
    assert_streq(line, "getpid#2()", "format getpid");
    format_event(line, 1, 1, 0x4000, 2, 0);
    assert_streq(line, "write#1(1, <ptr>, 2)", "format write (buf hermetic)");
    format_event(line, 0, 0, 0, 0, 0);
    assert_streq(line, "exit#0(0)", "format exit");
    format_event(line, 99, 0, 0, 0, 0);
    assert_streq(line, "unknown#99()", "format unknown number");

    # --- M1 pure translation contract -------------------------------------
    # agnos# -> Linux# remap (the direct-pass / execute-in-child family).
    test_group("xlat-nr");
    assert_eq(agnos_to_linux_nr(1), 1, "write 1->1");
    assert_eq(agnos_to_linux_nr(5), 0, "read 5->0 (DIFFERS)");
    assert_eq(agnos_to_linux_nr(2), 39, "getpid 2->39 (DIFFERS)");
    assert_eq(agnos_to_linux_nr(27), 9, "mmap 27->9");
    assert_eq(agnos_to_linux_nr(28), 11, "munmap 28->11");
    assert_eq(agnos_to_linux_nr(12), 162, "sync 12->162");
    assert_eq(agnos_to_linux_nr(45), 318, "getrandom 45->318 (DIFFERS)");
    assert_eq(agnos_to_linux_nr(46), 201, "time_unix 46->201");
    assert_eq(agnos_to_linux_nr(40), 0 - 1, "uptime_ms 40 -> no peer (emulated)");
    assert_eq(agnos_to_linux_nr(41), 0 - 1, "sleep_ms 41 -> no peer (emulated)");
    assert_eq(agnos_to_linux_nr(99), 0 - 1, "unknown 99 -> no peer");

    # mmap 2 MB round-up (the load-bearing arithmetic — off by a granule = segfault).
    test_group("xlat-mmap-round");
    assert_eq(mmap_round_up_2mb(0), 0, "0 -> 0");
    assert_eq(mmap_round_up_2mb(1), 2097152, "1 -> 2 MB");
    assert_eq(mmap_round_up_2mb(2097152), 2097152, "2 MB exact (no double-round)");
    assert_eq(mmap_round_up_2mb(2097153), 4194304, "2 MB + 1 -> 4 MB");
    assert_eq(mmap_round_up_2mb(4194304), 4194304, "4 MB exact");

    # is_linux_err: the signed [-4095,-1] band, NOT a high positive address.
    test_group("xlat-errband");
    assert_eq(is_linux_err(0 - 1), 1, "-1 is err");
    assert_eq(is_linux_err(0 - 4095), 1, "-4095 is err");
    assert_eq(is_linux_err(0 - 4096), 0, "-4096 not err");
    assert_eq(is_linux_err(0), 0, "0 not err");
    assert_eq(is_linux_err(0x7fff00000000), 0, "high addr not err (signedness)");

    # return-convention mapping (number-aware: mmap/time fail -> 0, else -1).
    test_group("xlat-ret");
    assert_eq(linux_ret_to_agnos(1, 0 - 9), 0 - 1, "write err -> -1");
    assert_eq(linux_ret_to_agnos(1, 13), 13, "write 13 passes");
    assert_eq(linux_ret_to_agnos(5, 0), 0, "read EOF 0 passes");
    assert_eq(linux_ret_to_agnos(27, 0 - 12), 0, "mmap fail -> 0 (not -1)");
    assert_eq(linux_ret_to_agnos(27, 0x7fff00000000), 0x7fff00000000, "mmap addr passes");
    assert_eq(linux_ret_to_agnos(46, 0 - 1), 0, "time fail -> 0 (not -1)");
    assert_eq(linux_ret_to_agnos(2, 1234), 1234, "getpid passes");

    # ms_from_timespec (uptime_ms emulation arithmetic).
    test_group("xlat-ms");
    assert_eq(ms_from_timespec(1, 500000000), 1500, "1s 500ms");
    assert_eq(ms_from_timespec(0, 0), 0, "zero");
    assert_eq(ms_from_timespec(0, 999999), 0, "sub-ms truncates");
    assert_eq(ms_from_timespec(10, 1000000), 10001, "10s + 1ms");

    # mmap 6-arg register synthesis into a seeded regs buffer.
    test_group("xlat-mmap-synth");
    var mr = alloc(USER_REGS_SIZE);
    synth_mmap_regs(mr, 2097152);
    assert_eq(load64(mr + 112), 0, "rdi addr = 0");
    assert_eq(load64(mr + 104), 2097152, "rsi len = 2 MB");
    assert_eq(load64(mr + 96), 3, "rdx prot = RW");
    assert_eq(load64(mr + 56), 0x22, "r10 flags = PRIVATE|ANON");
    assert_eq(load64(mr + 72), 0xFFFFFFFFFFFFFFFF, "r8 fd = -1");
    assert_eq(load64(mr + 64), 0, "r9 off = 0");
    synth_mmap_regs(mr, 1);
    assert_eq(load64(mr + 104), 2097152, "unaligned len rounds up");

    # --- M2 filesystem translation contract ------------------------------
    test_group("fs-nr");
    assert_eq(agnos_to_linux_nr(7), 2, "open 7->2");
    assert_eq(agnos_to_linux_nr(6), 3, "close 6->3");
    assert_eq(agnos_to_linux_nr(33), 4, "stat 33->4");
    assert_eq(agnos_to_linux_nr(58), 8, "lseek 58->8");
    assert_eq(agnos_to_linux_nr(8), 32, "dup 8->32");
    assert_eq(agnos_to_linux_nr(31), 82, "rename 31->82");
    assert_eq(agnos_to_linux_nr(9), 83, "mkdir 9->83");
    assert_eq(agnos_to_linux_nr(10), 84, "rmdir 10->84");
    assert_eq(agnos_to_linux_nr(32), 86, "link 32->86 (hardlink)");
    assert_eq(agnos_to_linux_nr(30), 87, "unlink 30->87");
    assert_eq(agnos_to_linux_nr(29), 217, "getdents 29->217");

    test_group("fs-ao-to-o");
    assert_eq(ao_to_o(0), 0, "RDONLY 0->0");
    assert_eq(ao_to_o(1), 1, "WRONLY 1->1");
    assert_eq(ao_to_o(2), 2, "RDWR 2->2");
    assert_eq(ao_to_o(0x100), 0x40, "AO_CREAT 0x100->O_CREAT 0x40");
    assert_eq(ao_to_o(0x200), 0x200, "AO_TRUNC same 0x200");
    assert_eq(ao_to_o(0x400), 0x400, "AO_APPEND same 0x400");
    assert_eq(ao_to_o(0x800), 0x10000, "AO_DIRECTORY 0x800->O_DIRECTORY 0x10000");
    assert_eq(ao_to_o(0x301), 0x241, "0x301 (WRONLY|CREAT|TRUNC) -> 0x241 (ground truth)");
    assert_eq(open_create_mode(), 384, "open mode = 0600 (0x180, least-privilege)");
    assert_eq(mkdir_create_mode(), 448, "mkdir mode = 0700 (0x1C0, least-privilege)");

    test_group("fs-dtype");
    assert_eq(dtype_to_agnos(8), 1, "DT_REG->file");
    assert_eq(dtype_to_agnos(4), 2, "DT_DIR->dir");
    assert_eq(dtype_to_agnos(10), 3, "DT_LNK->symlink");
    assert_eq(dtype_to_agnos(0), 0, "DT_UNKNOWN->unknown");
    assert_eq(dtype_to_agnos(6), 0, "DT_BLK->unknown");

    test_group("fs-stat-repack");
    var lb = alloc(144);
    store32(lb + 24, 0x81a4);          # st_mode = S_IFREG|0644
    store64(lb + 16, 2);               # st_nlink
    store64(lb + 48, 1234);            # st_size
    store64(lb + 8, 99);               # st_ino
    store64(lb + 64, 8);               # st_blocks
    store64(lb + 88, 1700000000);      # st_mtime (sec)
    var ab = alloc(48);
    stat_repack_144_to_48(lb, ab);
    assert_eq(load64(ab + 0), 0x81a4, "mode @0 (zero-extended)");
    assert_eq(load64(ab + 8), 2, "nlink @8");
    assert_eq(load64(ab + 16), 1234, "size @16");
    assert_eq(load64(ab + 24), 99, "ino @24");
    assert_eq(load64(ab + 32), 8, "blocks @32");
    assert_eq(load64(ab + 40), 1700000000, "mtime @40");

    test_group("fs-getdents-repack");
    # Two synthetic Linux getdents64 records: "alpha" (DT_REG, >32-bit ino), "beta" (DT_DIR).
    var glb = alloc(128);
    store64(glb + 0, 0x123456789A);    # rec0 d_ino@0 (low 32 = 0x3456789A)
    store16(glb + 16, 32);             # rec0 d_reclen@16 (padded)
    store8(glb + 18, 8);               # rec0 d_type@18 = DT_REG
    memcpy(glb + 19, "alpha", 5);
    store8(glb + 24, 0);               # NUL
    store64(glb + 32, 0xBB);           # rec1 d_ino@0 (offset 32)
    store16(glb + 48, 24);             # rec1 d_reclen@16
    store8(glb + 50, 4);               # rec1 d_type@18 = DT_DIR
    memcpy(glb + 51, "beta", 4);
    store8(glb + 55, 0);               # NUL
    var gab = alloc(128);
    var gbytes = getdents_repack(glb, 56, gab, 128);
    assert_eq(gbytes, 25, "two records repack to 13+12=25 bytes");
    assert_eq(load16(gab + 0), 13, "rec0 reclen = 8+5");
    assert_eq(load8(gab + 2), 1, "rec0 type = file");
    assert_eq(load8(gab + 3), 5, "rec0 namelen = 5");
    assert_eq(load32(gab + 4), 0x3456789A, "rec0 ino truncated to low 32");
    assert_eq(memeq(gab + 8, "alpha", 5), 1, "rec0 name = alpha (no NUL)");
    assert_eq(load16(gab + 13), 12, "rec1 reclen = 8+4");
    assert_eq(load8(gab + 15), 2, "rec1 type = dir");
    assert_eq(load8(gab + 16), 4, "rec1 namelen = 4");
    assert_eq(memeq(gab + 21, "beta", 4), 1, "rec1 name = beta");
    # Overflow: a tiny cap stops before the first record's 13 bytes.
    assert_eq(getdents_repack(glb, 56, gab, 10), 0, "cap 10 < 13 -> drop, return 0");

    # --- 0.7.1 path sanitization (the *at confinement gate — a bug here is an escape) ---
    test_group("sanitize-rootrel");
    var sb = alloc(64);
    memcpy(sb, "/etc/passwd", 11); store8(sb + 11, 0);
    assert_eq(sanitize_rootrel(sb), 0, "/etc/passwd ok");
    assert_streq(sb, "etc/passwd", "strip leading slash -> relative");
    memcpy(sb, "//foo", 5); store8(sb + 5, 0);
    assert_eq(sanitize_rootrel(sb), 0, "//foo ok");
    assert_streq(sb, "foo", "strip multiple leading slashes");
    memcpy(sb, "x/y", 3); store8(sb + 3, 0);
    assert_eq(sanitize_rootrel(sb), 0, "x/y ok");
    assert_streq(sb, "x/y", "relative path unchanged");
    memcpy(sb, "/", 1); store8(sb + 1, 0);
    assert_eq(sanitize_rootrel(sb), 0, "/ ok");
    assert_streq(sb, ".", "/ -> . (root dir)");
    store8(sb, 0);
    assert_eq(sanitize_rootrel(sb), 0, "empty ok");
    assert_streq(sb, ".", "empty -> .");
    memcpy(sb, "a/..foo", 7); store8(sb + 7, 0);
    assert_eq(sanitize_rootrel(sb), 0, "a/..foo ok (..foo is not ..)");
    assert_streq(sb, "a/..foo", "..foo preserved (not a .. component)");
    # ".." components in any position are REJECTED (-1):
    memcpy(sb, "/../etc", 7); store8(sb + 7, 0);
    assert_eq(sanitize_rootrel(sb), 0 - 1, "/../etc -> reject (leading ..)");
    memcpy(sb, "a/../b", 6); store8(sb + 6, 0);
    assert_eq(sanitize_rootrel(sb), 0 - 1, "a/../b -> reject (internal ..)");
    memcpy(sb, "a/b/..", 6); store8(sb + 6, 0);
    assert_eq(sanitize_rootrel(sb), 0 - 1, "a/b/.. -> reject (trailing ..)");
    memcpy(sb, "..", 2); store8(sb + 2, 0);
    assert_eq(sanitize_rootrel(sb), 0 - 1, ".. -> reject (bare)");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
