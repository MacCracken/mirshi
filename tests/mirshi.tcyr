# mirshi test suite
# Stdlib auto-included via cyrius.cyml
#
# The M0 decode/format logic (src/decode.cyr) is pure — no syscalls, no ptrace —
# so it is fully exercised here under `cyrius test`, hermetically, on any runner.
# The real fork+ptrace trap path is proven separately in scripts/it/m0_trap.sh
# (it needs an actual traced child, which a pure-cyrius .tcyr cannot express).

include "src/decode.cyr"
include "src/translate.cyr"
include "src/children.cyr"

fn main() {
    alloc_init();

    test_group("smoke");
    assert(1, "true is true");
    assert_eq(1 + 1, 2, "math works");

    # --- agnos number -> name decode ---------------------------------------
    test_group("decode-name");
    assert_streq(agnos_nr_name(0), "exit", "nr 0 = exit");
    assert_streq(agnos_nr_name(1), "write", "nr 1 = write");
    assert_streq(agnos_nr_name(2), "getpid", "nr 2 = getpid");
    assert_streq(agnos_nr_name(27), "mmap", "nr 27 = mmap");
    assert_streq(agnos_nr_name(60), "winsize", "nr 60 = winsize (NOT exit)");
    assert_streq(agnos_nr_name(61), "net_config", "nr 61 = net_config");
    assert_streq(agnos_nr_name(36), "unknown", "nr 36 = unknown (unmirrored)");
    assert_streq(agnos_nr_name(99), "unknown", "nr 99 = unknown (out of surface)");

    # --- register extraction from a synthetic user_regs_struct -------------
    # Catches the two classic ptrace bugs: reading rax (not orig_rax) for the
    # number, and reading rcx (not r10) for arg4.
    test_group("decode-regs");
    var regs = alloc(USER_REGS_SIZE);
    store64(regs + 120, 1);        # orig_rax = write#1
    store64(regs + 80, 0 - 38);    # rax = -ENOSYS (must be ignored)
    store64(regs + 112, 1);        # rdi  = a0 (fd 1)
    store64(regs + 104, 0x4000);   # rsi  = a1 (buf ptr)
    store64(regs + 96, 2);         # rdx  = a2 (count)
    store64(regs + 56, 7);         # r10  = a3
    assert_eq(decode_nr(regs), 1, "decode_nr reads orig_rax not rax");
    assert_eq(decode_arg(regs, 0), 1, "arg0 = rdi");
    assert_eq(decode_arg(regs, 1), 0x4000, "arg1 = rsi");
    assert_eq(decode_arg(regs, 2), 2, "arg2 = rdx");
    assert_eq(decode_arg(regs, 3), 7, "arg3 = r10 not rcx");

    # --- arity + pointer-arg tables ----------------------------------------
    test_group("decode-shape");
    assert_eq(agnos_argc(2), 0, "getpid arity 0");
    assert_eq(agnos_argc(1), 3, "write arity 3");
    assert_eq(agnos_argc(31), 4, "rename arity 4 (a4=r10)");
    assert_eq(agnos_ptrmask(1), 2, "write buf is arg1");
    assert_eq(agnos_ptrmask(33), 5, "stat path+statbuf are arg0+arg2");
    assert_eq(agnos_ptrmask(2), 0, "getpid has no pointer args");

    # --- full event formatting (the same lines the golden IT asserts) ------
    test_group("format");
    var line = alloc(256);
    format_event(line, 2, 0, 0, 0, 0);
    assert_streq(line, "getpid#2()", "format getpid");
    format_event(line, 1, 1, 0x4000, 2, 0);
    assert_streq(line, "write#1(1, <ptr>, 2)", "format write (buf hermetic)");
    format_event(line, 0, 0, 0, 0, 0);
    assert_streq(line, "exit#0(0)", "format exit");
    format_event(line, 99, 0, 0, 0, 0);
    assert_streq(line, "unknown#99()", "format unknown number");

    # --- M1 pure translation contract -------------------------------------
    # agnos# -> Linux# remap (the direct-pass / execute-in-child family).
    test_group("xlat-nr");
    assert_eq(agnos_to_linux_nr(1), 1, "write 1->1");
    assert_eq(agnos_to_linux_nr(5), 0, "read 5->0 (DIFFERS)");
    assert_eq(agnos_to_linux_nr(2), 39, "getpid 2->39 (DIFFERS)");
    assert_eq(agnos_to_linux_nr(27), 9, "mmap 27->9");
    assert_eq(agnos_to_linux_nr(28), 11, "munmap 28->11");
    assert_eq(agnos_to_linux_nr(12), 162, "sync 12->162");
    assert_eq(agnos_to_linux_nr(45), 318, "getrandom 45->318 (DIFFERS)");
    assert_eq(agnos_to_linux_nr(46), 201, "time_unix 46->201");
    assert_eq(agnos_to_linux_nr(40), 0 - 1, "uptime_ms 40 -> no peer (emulated)");
    assert_eq(agnos_to_linux_nr(41), 0 - 1, "sleep_ms 41 -> no peer (emulated)");
    assert_eq(agnos_to_linux_nr(99), 0 - 1, "unknown 99 -> no peer");

    # mmap 2 MB round-up (the load-bearing arithmetic — off by a granule = segfault).
    test_group("xlat-mmap-round");
    assert_eq(mmap_round_up_2mb(0), 0, "0 -> 0");
    assert_eq(mmap_round_up_2mb(1), 2097152, "1 -> 2 MB");
    assert_eq(mmap_round_up_2mb(2097152), 2097152, "2 MB exact (no double-round)");
    assert_eq(mmap_round_up_2mb(2097153), 4194304, "2 MB + 1 -> 4 MB");
    assert_eq(mmap_round_up_2mb(4194304), 4194304, "4 MB exact");

    # is_linux_err: the signed [-4095,-1] band, NOT a high positive address.
    test_group("xlat-errband");
    assert_eq(is_linux_err(0 - 1), 1, "-1 is err");
    assert_eq(is_linux_err(0 - 4095), 1, "-4095 is err");
    assert_eq(is_linux_err(0 - 4096), 0, "-4096 not err");
    assert_eq(is_linux_err(0), 0, "0 not err");
    assert_eq(is_linux_err(0x7fff00000000), 0, "high addr not err (signedness)");

    # return-convention mapping (number-aware: mmap/time fail -> 0, else -1).
    test_group("xlat-ret");
    assert_eq(linux_ret_to_agnos(1, 0 - 9), 0 - 1, "write err -> -1");
    assert_eq(linux_ret_to_agnos(1, 13), 13, "write 13 passes");
    assert_eq(linux_ret_to_agnos(5, 0), 0, "read EOF 0 passes");
    assert_eq(linux_ret_to_agnos(27, 0 - 12), 0, "mmap fail -> 0 (not -1)");
    assert_eq(linux_ret_to_agnos(27, 0x7fff00000000), 0x7fff00000000, "mmap addr passes");
    assert_eq(linux_ret_to_agnos(46, 0 - 1), 0, "time fail -> 0 (not -1)");
    assert_eq(linux_ret_to_agnos(2, 1234), 1234, "getpid passes");

    # ms_from_timespec (uptime_ms emulation arithmetic).
    test_group("xlat-ms");
    assert_eq(ms_from_timespec(1, 500000000), 1500, "1s 500ms");
    assert_eq(ms_from_timespec(0, 0), 0, "zero");
    assert_eq(ms_from_timespec(0, 999999), 0, "sub-ms truncates");
    assert_eq(ms_from_timespec(10, 1000000), 10001, "10s + 1ms");

    # mmap 6-arg register synthesis into a seeded regs buffer.
    test_group("xlat-mmap-synth");
    var mr = alloc(USER_REGS_SIZE);
    synth_mmap_regs(mr, 2097152);
    assert_eq(load64(mr + 112), 0, "rdi addr = 0");
    assert_eq(load64(mr + 104), 2097152, "rsi len = 2 MB");
    assert_eq(load64(mr + 96), 3, "rdx prot = RW");
    assert_eq(load64(mr + 56), 0x22, "r10 flags = PRIVATE|ANON");
    assert_eq(load64(mr + 72), 0xFFFFFFFFFFFFFFFF, "r8 fd = -1");
    assert_eq(load64(mr + 64), 0, "r9 off = 0");
    synth_mmap_regs(mr, 1);
    assert_eq(load64(mr + 104), 2097152, "unaligned len rounds up");

    # --- M2 filesystem translation contract ------------------------------
    test_group("fs-nr");
    assert_eq(agnos_to_linux_nr(7), 2, "open 7->2");
    assert_eq(agnos_to_linux_nr(6), 3, "close 6->3");
    assert_eq(agnos_to_linux_nr(33), 4, "stat 33->4");
    assert_eq(agnos_to_linux_nr(58), 8, "lseek 58->8");
    assert_eq(agnos_to_linux_nr(8), 32, "dup 8->32");
    assert_eq(agnos_to_linux_nr(31), 82, "rename 31->82");
    assert_eq(agnos_to_linux_nr(9), 83, "mkdir 9->83");
    assert_eq(agnos_to_linux_nr(10), 84, "rmdir 10->84");
    assert_eq(agnos_to_linux_nr(32), 86, "link 32->86 (hardlink)");
    assert_eq(agnos_to_linux_nr(30), 87, "unlink 30->87");
    assert_eq(agnos_to_linux_nr(29), 217, "getdents 29->217");

    # --- FROZEN CONTRACT (0.9.0): exhaustive disposition of every agnos# 0-61. The
    #     mapped (EXECUTE) numbers are pinned above (xlat-nr + fs-nr); here every
    #     remaining number is pinned to -1 ("no direct peer"), which is what
    #     agnos_to_linux_nr returns for exit#0 (EXIT, special-cased to exit_group),
    #     the emulated timers #40/#41 (EMULATE), and the whole out-of-surface set
    #     (ENOSYS). Adding a mapping is then a DELIBERATE contract change that must
    #     update this freeze + docs/reference/syscall-coverage.md.
    test_group("xlat-coverage");
    assert_eq(agnos_to_linux_nr(0), 0 - 1, "exit#0 -> no peer (EXIT: exit_group, special)");
    assert_eq(agnos_to_linux_nr(3), 0 - 1, "spawn#3 -> ENOSYS (multi-proc)");
    assert_eq(agnos_to_linux_nr(4), 0 - 1, "waitpid#4 -> ENOSYS (multi-proc)");
    assert_eq(agnos_to_linux_nr(11), 0 - 1, "mount#11 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(13), 0 - 1, "reboot#13 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(14), 0 - 1, "pause#14 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(15), 0 - 1, "getuid#15 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(16), 0 - 1, "kill#16 -> ENOSYS (signals)");
    assert_eq(agnos_to_linux_nr(17), 0 - 1, "sigprocmask#17 -> ENOSYS (signals)");
    assert_eq(agnos_to_linux_nr(18), 0 - 1, "signalfd#18 -> ENOSYS (signals)");
    assert_eq(agnos_to_linux_nr(19), 0 - 1, "epoll_create#19 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(20), 0 - 1, "epoll_ctl#20 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(21), 0 - 1, "epoll_wait#21 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(22), 0 - 1, "timerfd_create#22 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(23), 0 - 1, "timerfd_settime#23 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(24), 0 - 1, "umount#24 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(25), 0 - 1, "pipe#25 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(26), 0 - 1, "write_boot_checkpoint#26 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(34), 0 - 1, "uname#34 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(35), 0 - 1, "sysinfo#35 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(36), 0 - 1, "undefined#36 -> ENOSYS (ABI gap)");
    assert_eq(agnos_to_linux_nr(37), 0 - 1, "undefined#37 -> ENOSYS (ABI gap)");
    assert_eq(agnos_to_linux_nr(38), 0 - 1, "undefined#38 -> ENOSYS (ABI gap)");
    assert_eq(agnos_to_linux_nr(39), 0 - 1, "undefined#39 -> ENOSYS (ABI gap)");
    assert_eq(agnos_to_linux_nr(42), 0 - 1, "undefined#42 -> ENOSYS (ABI gap)");
    assert_eq(agnos_to_linux_nr(43), 0 - 1, "undefined#43 -> ENOSYS (ABI gap)");
    assert_eq(agnos_to_linux_nr(44), 0 - 1, "undefined#44 -> ENOSYS (ABI gap)");
    assert_eq(agnos_to_linux_nr(47), 0 - 1, "sock_connect#47 -> ENOSYS (net band)");
    assert_eq(agnos_to_linux_nr(48), 0 - 1, "sock_send#48 -> ENOSYS (net band)");
    assert_eq(agnos_to_linux_nr(49), 0 - 1, "sock_recv#49 -> ENOSYS (net band)");
    assert_eq(agnos_to_linux_nr(50), 0 - 1, "sock_close#50 -> ENOSYS (net band)");
    assert_eq(agnos_to_linux_nr(51), 0 - 1, "udp_bind#51 -> ENOSYS (net band)");
    assert_eq(agnos_to_linux_nr(52), 0 - 1, "udp_send#52 -> ENOSYS (net band)");
    assert_eq(agnos_to_linux_nr(53), 0 - 1, "udp_recv#53 -> ENOSYS (net band)");
    assert_eq(agnos_to_linux_nr(54), 0 - 1, "udp_unbind#54 -> ENOSYS (net band)");
    assert_eq(agnos_to_linux_nr(55), 0 - 1, "icmp_echo#55 -> ENOSYS (net band)");
    assert_eq(agnos_to_linux_nr(56), 0 - 1, "sock_listen#56 -> ENOSYS (net band)");
    assert_eq(agnos_to_linux_nr(57), 0 - 1, "sock_accept#57 -> ENOSYS (net band)");
    assert_eq(agnos_to_linux_nr(59), 0 - 1, "flock#59 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(60), 0 - 1, "winsize#60 -> ENOSYS (graphics)");
    assert_eq(agnos_to_linux_nr(61), 0 - 1, "net_config#61 -> ENOSYS (net band)");
    assert_eq(agnos_to_linux_nr(62), 0 - 1, "out-of-range#62 -> ENOSYS");
    assert_eq(agnos_to_linux_nr(1000), 0 - 1, "far out-of-range -> ENOSYS");

    test_group("fs-ao-to-o");
    assert_eq(ao_to_o(0), 0, "RDONLY 0->0");
    assert_eq(ao_to_o(1), 1, "WRONLY 1->1");
    assert_eq(ao_to_o(2), 2, "RDWR 2->2");
    assert_eq(ao_to_o(0x100), 0x40, "AO_CREAT 0x100->O_CREAT 0x40");
    assert_eq(ao_to_o(0x200), 0x200, "AO_TRUNC same 0x200");
    assert_eq(ao_to_o(0x400), 0x400, "AO_APPEND same 0x400");
    assert_eq(ao_to_o(0x800), 0x10000, "AO_DIRECTORY 0x800->O_DIRECTORY 0x10000");
    assert_eq(ao_to_o(0x301), 0x241, "0x301 (WRONLY|CREAT|TRUNC) -> 0x241 (ground truth)");
    assert_eq(open_create_mode(), 384, "open mode = 0600 (0x180, least-privilege)");
    assert_eq(mkdir_create_mode(), 448, "mkdir mode = 0700 (0x1C0, least-privilege)");

    test_group("fs-dtype");
    assert_eq(dtype_to_agnos(8), 1, "DT_REG->file");
    assert_eq(dtype_to_agnos(4), 2, "DT_DIR->dir");
    assert_eq(dtype_to_agnos(10), 3, "DT_LNK->symlink");
    assert_eq(dtype_to_agnos(0), 0, "DT_UNKNOWN->unknown");
    assert_eq(dtype_to_agnos(6), 0, "DT_BLK->unknown");

    test_group("fs-stat-repack");
    var lb = alloc(144);
    store32(lb + 24, 0x81a4);          # st_mode = S_IFREG|0644
    store64(lb + 16, 2);               # st_nlink
    store64(lb + 48, 1234);            # st_size
    store64(lb + 8, 99);               # st_ino
    store64(lb + 64, 8);               # st_blocks
    store64(lb + 88, 1700000000);      # st_mtime (sec)
    var ab = alloc(48);
    stat_repack_144_to_48(lb, ab);
    assert_eq(load64(ab + 0), 0x81a4, "mode @0 (zero-extended)");
    assert_eq(load64(ab + 8), 2, "nlink @8");
    assert_eq(load64(ab + 16), 1234, "size @16");
    assert_eq(load64(ab + 24), 99, "ino @24");
    assert_eq(load64(ab + 32), 8, "blocks @32");
    assert_eq(load64(ab + 40), 1700000000, "mtime @40");

    test_group("fs-getdents-repack");
    # Two synthetic Linux getdents64 records: "alpha" (DT_REG, >32-bit ino), "beta" (DT_DIR).
    var glb = alloc(128);
    store64(glb + 0, 0x123456789A);    # rec0 d_ino@0 (low 32 = 0x3456789A)
    store16(glb + 16, 32);             # rec0 d_reclen@16 (padded)
    store8(glb + 18, 8);               # rec0 d_type@18 = DT_REG
    memcpy(glb + 19, "alpha", 5);
    store8(glb + 24, 0);               # NUL
    store64(glb + 32, 0xBB);           # rec1 d_ino@0 (offset 32)
    store16(glb + 48, 24);             # rec1 d_reclen@16
    store8(glb + 50, 4);               # rec1 d_type@18 = DT_DIR
    memcpy(glb + 51, "beta", 4);
    store8(glb + 55, 0);               # NUL
    var gab = alloc(128);
    var gbytes = getdents_repack(glb, 56, gab, 128);
    assert_eq(gbytes, 25, "two records repack to 13+12=25 bytes");
    assert_eq(load16(gab + 0), 13, "rec0 reclen = 8+5");
    assert_eq(load8(gab + 2), 1, "rec0 type = file");
    assert_eq(load8(gab + 3), 5, "rec0 namelen = 5");
    assert_eq(load32(gab + 4), 0x3456789A, "rec0 ino truncated to low 32");
    assert_eq(memeq(gab + 8, "alpha", 5), 1, "rec0 name = alpha (no NUL)");
    assert_eq(load16(gab + 13), 12, "rec1 reclen = 8+4");
    assert_eq(load8(gab + 15), 2, "rec1 type = dir");
    assert_eq(load8(gab + 16), 4, "rec1 namelen = 4");
    assert_eq(memeq(gab + 21, "beta", 4), 1, "rec1 name = beta");
    # Overflow: a tiny cap stops before the first record's 13 bytes.
    assert_eq(getdents_repack(glb, 56, gab, 10), 0, "cap 10 < 13 -> drop, return 0");

    # --- 0.7.1 path sanitization (the *at confinement gate — a bug here is an escape) ---
    test_group("sanitize-rootrel");
    var sb = alloc(64);
    memcpy(sb, "/etc/passwd", 11); store8(sb + 11, 0);
    assert_eq(sanitize_rootrel(sb), 0, "/etc/passwd ok");
    assert_streq(sb, "etc/passwd", "strip leading slash -> relative");
    memcpy(sb, "//foo", 5); store8(sb + 5, 0);
    assert_eq(sanitize_rootrel(sb), 0, "//foo ok");
    assert_streq(sb, "foo", "strip multiple leading slashes");
    memcpy(sb, "x/y", 3); store8(sb + 3, 0);
    assert_eq(sanitize_rootrel(sb), 0, "x/y ok");
    assert_streq(sb, "x/y", "relative path unchanged");
    memcpy(sb, "/", 1); store8(sb + 1, 0);
    assert_eq(sanitize_rootrel(sb), 0, "/ ok");
    assert_streq(sb, ".", "/ -> . (root dir)");
    store8(sb, 0);
    assert_eq(sanitize_rootrel(sb), 0, "empty ok");
    assert_streq(sb, ".", "empty -> .");
    memcpy(sb, "a/..foo", 7); store8(sb + 7, 0);
    assert_eq(sanitize_rootrel(sb), 0, "a/..foo ok (..foo is not ..)");
    assert_streq(sb, "a/..foo", "..foo preserved (not a .. component)");
    # ".." components in any position are REJECTED (-1):
    memcpy(sb, "/../etc", 7); store8(sb + 7, 0);
    assert_eq(sanitize_rootrel(sb), 0 - 1, "/../etc -> reject (leading ..)");
    memcpy(sb, "a/../b", 6); store8(sb + 6, 0);
    assert_eq(sanitize_rootrel(sb), 0 - 1, "a/../b -> reject (internal ..)");
    memcpy(sb, "a/b/..", 6); store8(sb + 6, 0);
    assert_eq(sanitize_rootrel(sb), 0 - 1, "a/b/.. -> reject (trailing ..)");
    memcpy(sb, "..", 2); store8(sb + 2, 0);
    assert_eq(sanitize_rootrel(sb), 0 - 1, ".. -> reject (bare)");

    # --- Net band (v1.1.0) pure helpers (docs/adr/0012) --------------------
    test_group("net-htons");
    assert_eq(net_htons(80), 0x5000, "htons(80)=0x5000");
    assert_eq(net_htons(0x1234), 0x3412, "htons(0x1234)=0x3412");
    assert_eq(net_htons(443), 0xBB01, "htons(443)=0xBB01");
    assert_eq(net_htons(0), 0, "htons(0)=0");

    # kernel-ip4 form (oct1<<24|...) -> sin_addr network-order value; the loopback
    # 0x7F000001 <-> 0x0100007F case is THE endianness trap (lib/net.cyr bswap32's it).
    test_group("net-ip4-to-inaddr");
    assert_eq(net_ip4_to_inaddr(0x7F000001), 0x0100007F, "127.0.0.1 (loopback trap)");
    assert_eq(net_ip4_to_inaddr(0x08080808), 0x08080808, "8.8.8.8 (palindrome)");
    assert_eq(net_ip4_to_inaddr(0x01020304), 0x04030201, "1.2.3.4 byteswap");
    assert_eq(net_ip4_to_inaddr(0xC0A80101), 0x0101A8C0, "192.168.1.1");

    test_group("net-sockaddr-in");
    var sa = alloc(SOCKADDR_IN_SIZE);
    build_sockaddr_in(sa, 0x7F000001, 80);
    assert_eq(load16(sa + 0), 2, "sin_family = AF_INET(2)");
    assert_eq(load16(sa + 2), 0x5000, "sin_port = htons(80)");
    assert_eq(load32(sa + 4), 0x0100007F, "sin_addr = 127.0.0.1 network order");
    assert_eq(load64(sa + 8), 0, "sin_zero = 0");

    # THE subtle one: agnos recv is INVERTED vs Linux (0=WOULD_BLOCK/-1=EOF).
    test_group("net-recv-inversion");
    assert_eq(net_recv_to_agnos(5), 5, "recv 5 bytes passes");
    assert_eq(net_recv_to_agnos(1460), 1460, "recv full MSS passes");
    assert_eq(net_recv_to_agnos(0), 0 - 1, "Linux EOF 0 -> agnos EOF -1 [INVERTED]");
    assert_eq(net_recv_to_agnos(0 - 11), 0, "-EAGAIN -> agnos WOULD_BLOCK 0 [INVERTED]");
    assert_eq(net_recv_to_agnos(0 - 104), 0 - 1, "-ECONNRESET -> agnos error -1");

    # --- Net egress policy (v1.1.0 --net-allow) pure logic (docs/adr/0012) --
    test_group("net-prefix-mask");
    assert_eq(net_prefix_mask(0), 0, "/0 -> 0");
    assert_eq(net_prefix_mask(8), 0xFF000000, "/8");
    assert_eq(net_prefix_mask(12), 0xFFF00000, "/12");
    assert_eq(net_prefix_mask(24), 0xFFFFFF00, "/24");
    assert_eq(net_prefix_mask(32), 0xFFFFFFFF, "/32");

    test_group("net-in-cidr");
    assert_eq(net_in_cidr(0x0A050507, 0x0A000000, 8), 1, "10.5.5.7 in 10/8");
    assert_eq(net_in_cidr(0x0B050507, 0x0A000000, 8), 0, "11.5.5.7 not in 10/8");
    assert_eq(net_in_cidr(0x7F000001, 0, 0), 1, "anything in 0/0");
    assert_eq(net_in_cidr(0xC0A80105, 0xC0A80100, 24), 1, "192.168.1.5 in 192.168.1/24");
    assert_eq(net_in_cidr(0xC0A80205, 0xC0A80100, 24), 0, "192.168.2.5 not in .1/24");

    test_group("net-reserved-prefix");
    assert_eq(net_reserved_min_prefix(0xA9FEA9FE), 32, "metadata -> /32");
    assert_eq(net_reserved_min_prefix(0xA9FE0101), 16, "link-local -> /16");
    assert_eq(net_reserved_min_prefix(0x7F000001), 8, "loopback -> /8");
    assert_eq(net_reserved_min_prefix(0x0A050507), 8, "10/8 -> /8");
    assert_eq(net_reserved_min_prefix(0xAC1F0001), 12, "172.31 (172.16/12) -> /12");
    assert_eq(net_reserved_min_prefix(0xAC0F0001), 0, "172.15 not reserved -> 0");
    assert_eq(net_reserved_min_prefix(0xC0A80101), 16, "192.168 -> /16");
    assert_eq(net_reserved_min_prefix(0x08080808), 0, "8.8.8.8 public -> 0");

    test_group("net-egress-parse+decide");
    var ent = alloc(NET_ALLOW_MAX * ENTRY_SIZE);
    assert_eq(net_parse_allow("", ent, NET_ALLOW_MAX), 0, "empty -> 0 entries");
    assert_eq(net_egress_ok(0x08080808, ent, 0), 0, "default-deny: no allow -> deny");
    var n1 = net_parse_allow("93.184.216.0/24", ent, NET_ALLOW_MAX);
    assert_eq(n1, 1, "one CIDR parsed");
    assert_eq(net_egress_ok(0x5DB8D822, ent, n1), 1, "93.184.216.34 allowed");
    assert_eq(net_egress_ok(0x5DB8D922, ent, n1), 0, "93.184.217.34 denied (outside /24)");
    # SSRF: broad 0/0 must NOT implicitly expose reserved blocks
    var n2 = net_parse_allow("0.0.0.0/0", ent, NET_ALLOW_MAX);
    assert_eq(net_egress_ok(0x08080808, ent, n2), 1, "0/0 allows public 8.8.8.8");
    assert_eq(net_egress_ok(0x0A050507, ent, n2), 0, "0/0 does NOT expose RFC1918 [SSRF]");
    assert_eq(net_egress_ok(0xA9FEA9FE, ent, n2), 0, "0/0 does NOT expose metadata [SSRF]");
    # specific allow DOES reach a reserved block
    var n3 = net_parse_allow("127.0.0.1/32,10.0.0.0/8", ent, NET_ALLOW_MAX);
    assert_eq(n3, 2, "two CIDRs");
    assert_eq(net_egress_ok(0x7F000001, ent, n3), 1, "127.0.0.1/32 allows loopback");
    assert_eq(net_egress_ok(0x0A050507, ent, n3), 1, "10/8 allows RFC1918");
    assert_eq(net_egress_ok(0x7F000002, ent, n3), 0, "127.0.0.2 denied (only .1/32 allowed)");
    # malformed -> -1 (fail-closed)
    assert_eq(net_parse_allow("1.2.3.256/24", ent, NET_ALLOW_MAX), 0 - 1, "octet>255 rejected");
    assert_eq(net_parse_allow("1.2.3.4/33", ent, NET_ALLOW_MAX), 0 - 1, "prefix>32 rejected");
    assert_eq(net_parse_allow("1.2.3/24", ent, NET_ALLOW_MAX), 0 - 1, "missing octet rejected");
    assert_eq(net_parse_allow("1.2.3.4/24x", ent, NET_ALLOW_MAX), 0 - 1, "trailing junk rejected");
    assert_eq(net_parse_allow("99999999999999999999.0.0.0/8", ent, NET_ALLOW_MAX), 0 - 1, "overflow octet rejected (in-loop bound)");

    # net_config#61 parsing helpers (v1.3.0): dotted-quad + /proc/net/route hex.
    test_group("net-config-parse");
    var dq = alloc(32);
    memcpy(dq, "127.0.0.53", 10); store8(dq + 10, 0);
    assert_eq(net_parse_dotquad(dq, 10), 0x7F000035, "127.0.0.53 -> kernel-ip4");
    memcpy(dq, "8.8.8.8 x", 9); store8(dq + 9, 0);
    assert_eq(net_parse_dotquad(dq, 9), 0x08080808, "8.8.8.8 (stops at trailing space)");
    memcpy(dq, "1.2.3.4", 7); store8(dq + 7, 0);
    assert_eq(net_parse_dotquad(dq, 7), 0x01020304, "1.2.3.4");
    memcpy(dq, "256.0.0.1", 9); store8(dq + 9, 0);
    assert_eq(net_parse_dotquad(dq, 9), 0 - 1, "256.0.0.1 -> reject");
    memcpy(dq, "0101A8C0", 8); store8(dq + 8, 0);
    assert_eq(net_parse_hex32(dq), 0x0101A8C0, "route hex 0101A8C0 (LE sin_addr)");
    assert_eq(net_ip4_to_inaddr(net_parse_hex32(dq)), 0xC0A80101, "…bswapped -> 192.168.1.1 kernel-ip4");
    memcpy(dq, "00000000", 8); store8(dq + 8, 0);
    assert_eq(net_parse_hex32(dq), 0, "route hex 00000000 -> 0");

    # --- v1.5.0 multi-process: the per-child record table (src/children.cyr) -------------
    test_group("child-table");
    _child_reset();
    assert_eq(_child_find_by_host(1234), 0, "empty table: host miss -> 0");
    assert_eq(_child_find_by_agnos(1), 0, "empty table: agnos miss -> 0");
    # the root: coined agnos_pid 1, host_pid 1000, parent 0, RUNNING
    var r0 = _child_alloc(1000, 0);
    assert(r0 != 0, "alloc root -> non-null record");
    assert_eq(load64(r0 + C_AGNOS_PID), 1, "root coined agnos_pid = 1");
    assert_eq(load64(r0 + C_HOST_PID), 1000, "root host_pid = 1000");
    assert_eq(load64(r0 + C_STATE), CS_RUNNING, "root state = RUNNING");
    assert_eq(load64(r0 + C_AT_ENTRY), 1, "root at_entry = 1 (first stop is a syscall-enter)");
    # a spawned child: next agnos_pid 2 (monotonic), parent 1
    var r1 = _child_alloc(1001, 1);
    assert_eq(load64(r1 + C_AGNOS_PID), 2, "child coined agnos_pid = 2 (monotonic)");
    assert_eq(load64(r1 + C_PARENT), 1, "child parent_agnos_pid = 1");
    # two-way lookup resolves to the right records
    assert_eq(_child_find_by_host(1000), r0, "find root by host pid");
    assert_eq(_child_find_by_agnos(2), r1, "find child by agnos pid");
    assert_eq(_child_find_by_host(9999), 0, "unknown host pid -> 0");
    # the MAX_CHILDREN storm bound
    _child_reset();
    var k = 0;
    var all_ok = 1;
    while (k < MAX_CHILDREN) {
        if (_child_alloc(2000 + k, 0) == 0) { all_ok = 0; }
        k = k + 1;
    }
    assert_eq(all_ok, 1, "all MAX_CHILDREN allocs succeed");
    assert_eq(_child_alloc(9000, 0), 0, "alloc past MAX_CHILDREN -> 0 (storm bound)");
    # agnos pids are never reused (monotonic coiner)
    _child_reset();
    _child_alloc(1, 0);
    assert_eq(load64(_child_alloc(2, 0) + C_AGNOS_PID), 2, "agnos pids monotonic across allocs");

    # --- v1.5.0 spawn#3 ELF-size bounds (src/children.cyr _spawn_size_ok) -----------------
    test_group("spawn-elf-size");
    assert_eq(_spawn_size_ok(0), 0, "size 0 -> reject");
    assert_eq(_spawn_size_ok(0 - 1), 0, "negative size -> reject");
    assert_eq(_spawn_size_ok(1), 1, "size 1 -> ok");
    assert_eq(_spawn_size_ok(SPAWN_ELF_MAX), 1, "size == cap -> ok");
    assert_eq(_spawn_size_ok(SPAWN_ELF_MAX + 1), 0, "size > cap -> reject");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
