[package]
name = "mirshi"
version = "${file:VERSION}"
description = "mirshi — mirror-shim: bidirectional AGNOS↔Linux syscall-ABI translation. v1 = run agnos-compiled userland as native Linux processes in a plain Docker container (no QEMU, shared host kernel)."
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "6.3.26"

[build]
entry = "src/main.cyr"
test = "src/test.cyr"
output = "mirshi"

[deps]
stdlib = ["string", "fmt", "alloc", "io", "vec", "str", "syscalls", "assert", "bench", "args"]
